// --- LOGIC FUNCTIONS ---

function generateCharacterData() {
    var data = {};
    data.gender = resolveAttribute(selections.gender, genders);
    data.nation = resolveAttribute(selections.nationality, nationalities);
    data.age = resolveAttribute(selections.age, ages);
    data.skin = resolveAttribute(selections.skin, skinDetails);
    data.build = resolveAttribute(selections.build, bodyBuilds);
    data.shape = resolveAttribute(selections.shape, bodyShapes);
    data.hairS = resolveAttribute(selections.hairStyle, hairStyles);
    data.hairC = resolveAttribute(selections.hairColor, hairColors);
    data.eyes = resolveAttribute(selections.eyes, eyeColors);

    // Celeb Logic
    var celA = "";
    if (selections.celebA === 1) celA = getRandomItem(celebrities, 2);
    else if (selections.celebA > 1) celA = celebrities[selections.celebA];

    var celB = "";
    if (selections.celebB === 1) celB = getRandomItem(celebrities, 2);
    else if (selections.celebB > 1) celB = celebrities[selections.celebB];

    data.celebPrompt = "";
    if (celA && celB && celA !== celB) data.celebPrompt = "blend of " + celA + " and " + celB;
    else if (celA) data.celebPrompt = celA;
    else if (celB) data.celebPrompt = celB;

    return data;
}

function generateSceneContext() {
    var data = {};
    data.framing = resolveAttribute(selections.framing, framing);
    data.angle = resolveAttribute(selections.angle, angles);
    data.expression = resolveAttribute(selections.expression, expressions);
    data.style = resolveAttribute(selections.style, styles);
    data.attire = resolveAttribute(selections.attire, attireContexts);
    return data;
}

// --- PROMPT CONSTRUCTORS ---

function buildFluxPrompt(char, scene, extra) {
    var p = "Single person character portrait. ";
    p += "A " + scene.style + " " + scene.framing + " capturing a single, solitary " + char.age + " " + char.gender + ". ";
    p += "The subject is alone. "; 
    p += "The subject has " + char.nation + " characteristics. ";
    p += "Their body is " + char.build + " with " + char.shape + ". ";
    p += "They have " + char.skin + " and " + char.hairC + " " + char.hairS + ". ";
    p += "Their eyes are " + char.eyes + ". ";
    
    if (char.celebPrompt) {
        p += "The facial structure resembles a " + char.celebPrompt + ". ";
    }

    p += "The character is wearing " + scene.attire + ". ";
    p += "They are looking at the camera with a " + scene.expression + ". ";
    p += "The camera angle is " + scene.angle + ". ";

    if (extra && extra.trim() !== "") {
        p += "Additional details: " + extra + ".";
    }
    
    return p;
}

function buildSDXLPrompt(char, scene, extra) {
    var soloTag = getSubjectTag(char.gender);

    var p = soloTag + ", " + scene.style + ", " + scene.framing + ", " + scene.angle + ", ";
    
    p += char.gender + ", " + char.age + ", " + char.nation + ", ";
    p += "body type " + char.build + ", " + char.shape + ", ";
    p += "skin texture " + char.skin + ", ";
    p += char.hairC + " " + char.hairS + ", " + char.eyes + " eyes, ";
    
    if (char.celebPrompt) {
        p += "face mix " + char.celebPrompt + ", ";
    }

    p += "wearing " + scene.attire + ", ";
    p += scene.expression + ", ";

    if (extra && extra.trim() !== "") {
        p += extra + ", ";
    }

    p += "masterpiece, best quality, highly detailed, sharp focus, 8k, uhd, dslr, soft lighting, film grain.";
    return p;
}

