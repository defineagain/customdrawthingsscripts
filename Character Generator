// --- UTILITY FUNCTIONS ---

function getRandomItem(arr, startIndex) {
    var start = (startIndex === undefined) ? 1 : startIndex;
    var index = Math.floor(Math.random() * (arr.length - start)) + start;
    return arr[index];
}

function resolveAttribute(selectedIndex, dataArray) {
    if (selectedIndex > 0) {
        return dataArray[selectedIndex];
    }
    return getRandomItem(dataArray, 1);
}

// Helper to determine weighted subject tag based on gender
function getSubjectTag(genderString) {
    if (genderString.includes("Female") || genderString.includes("Trans Femme")) return "(1woman:1.4), (solo:1.3)";
    if (genderString.includes("Male") || genderString.includes("Trans Masc")) return "(1man:1.4), (solo:1.3)";
    return "(1person:1.4), (solo:1.3)";
}

